rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /ticket-attachments/{orgId}/{allPaths=**} {
      allow read:  if true;
      allow write: if true;
    }
    match /profiles/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
